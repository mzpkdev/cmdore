{
    "compilerOptions": {
        "target": "esnext",
        "module": "commonjs",
        "moduleResolution": "node",
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "incremental": true,
        "noEmitOnError": true,
        "importHelpers": true,
        "downlevelIteration": true,
        "newLine": "lf",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "lib": ["es2024"],
        "types": ["node"],
        "paths": {
            "@/*": ["./lib/*"],
            "cmdore": ["./lib/index.ts"]
        },
        "plugins": [
            {
                "transform": "typescript-transform-paths"
            },
            {
                "transform": "typescript-transform-paths",
                "afterDeclarations": true
            }
        ]
    },
    "include": ["lib/**/*.ts"],
    "exclude": [
        "node_modules",
        "lib/**/*.d.ts",
        "lib/**/*.js",
        "**/*.spec.ts",
        "**/*.test-d.ts",
        "vitest.config.ts",
        "examples"
    ]
}
